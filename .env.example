# ── Horror Fingers — Environment Variables ───────────────────────────────────
#
# Copy this file to .env (never commit .env to git).
#
# All variables are OPTIONAL — the app runs perfectly without any of them.
# Vite exposes only variables prefixed with VITE_ to the browser bundle.

# ── Analytics (Google Analytics 4) ──────────────────────────────────────────
#
# 1. Go to  https://analytics.google.com  → create a new GA4 property
# 2. Copy your Measurement ID  (format: G-XXXXXXXXXX)
# 3. Paste it here and deploy
#
# Leave empty / commented out to run with zero analytics.
#
# IMPORTANT: if you set this, also un-comment the GA4 domains in the
# Content-Security-Policy inside index.html and in vercel.json / netlify.toml.
#
# VITE_GA_ID=G-XXXXXXXXXX


# ── App customisation ────────────────────────────────────────────────────────
#
# Override the browser-tab title (optional)
# VITE_APP_TITLE=Horror Fingers
